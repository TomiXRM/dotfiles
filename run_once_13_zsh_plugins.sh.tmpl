{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

echo "=== [run_once_13_zsh_plugins] Started at $(date) ==="

# Plugins are now managed by .chezmoiexternal.toml (git-repo type).
# Clean up old plugin directory if it exists.
OLD_ZSH_PLUGINS_DIR="${HOME}/.local/share/zsh-plugins"
if [ -d "$OLD_ZSH_PLUGINS_DIR" ]; then
  echo "Removing old zsh-plugins directory: $OLD_ZSH_PLUGINS_DIR"
  rm -rf "$OLD_ZSH_PLUGINS_DIR"
fi

echo "=== [run_once_13_zsh_plugins] Completed ==="
{{- end -}}
