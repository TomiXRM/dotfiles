[user]
	name = tomixrm
	email = 20753105+TomiXRM@users.noreply.github.com
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color]
	ui = true
[core]
	editor = nano
	autoCRLF = input
	symlinks = true
	excludesFile = ~/.config/git/ignore
	pager = delta
[commit]
	template = ~/.config/git/commit_template
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	syntax-theme = Monokai Extended
	line-numbers = true
[merge]
	conflictStyle = zdiff3
[credential "https://github.com"]
	helper =
	helper = !{{ if eq .chezmoi.os "darwin" }}/opt/homebrew/bin/gh{{ else }}/usr/bin/gh{{ end }} auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !{{ if eq .chezmoi.os "darwin" }}/opt/homebrew/bin/gh{{ else }}/usr/bin/gh{{ end }} auth git-credential
[help]
	autocorrect = 50
