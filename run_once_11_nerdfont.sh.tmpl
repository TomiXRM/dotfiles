#!/usr/bin/env bash
set -euo pipefail

echo "=== [run_once_11_nerdfont] Started at $(date) ==="

# ==============================================================
# Font directory (OS-specific)
# ==============================================================
{{ if eq .chezmoi.os "linux" -}}
FONT_DIR="${HOME}/.local/share/fonts"
{{ else if eq .chezmoi.os "darwin" -}}
FONT_DIR="${HOME}/Library/Fonts"
{{ end -}}
mkdir -p "$FONT_DIR"

# ==============================================================
# Nerd Fonts zip archives (from GitHub releases)
# Add font family names to NERD_FONTS array to install them.
# Available families: https://github.com/ryanoasis/nerd-fonts/releases
# ==============================================================
NERD_FONTS_VERSION="v3.3.0"
NERD_FONTS=(
  JetBrainsMono
  FiraCode
  Hack
)

for font in "${NERD_FONTS[@]}"; do
  font_dir="$FONT_DIR/$font"
  if [ -d "$font_dir" ] && [ -n "$(ls -A "$font_dir" 2>/dev/null)" ]; then
    echo "Already exists: $font"
    continue
  fi
  echo "Downloading Nerd Font: $font (${NERD_FONTS_VERSION})"
  mkdir -p "$font_dir"
  curl -fsSL \
    "https://github.com/ryanoasis/nerd-fonts/releases/download/${NERD_FONTS_VERSION}/${font}.zip" \
    -o "/tmp/${font}.zip"
  unzip -o "/tmp/${font}.zip" -d "$font_dir/"
  rm -f "/tmp/${font}.zip"
  find "$font_dir" -name "*Windows Compatible*" -delete
done

# ==============================================================
# Font cache refresh (Linux only; macOS detects fonts automatically)
# ==============================================================
{{ if eq .chezmoi.os "linux" -}}
echo "Updating font cache..."
fc-cache -f "$FONT_DIR"
{{ end -}}

echo "=== [run_once_11_nerdfont] Completed ==="
echo ""
echo "=============================================="
echo "  IMPORTANT: Terminal Font Configuration"
echo "=============================================="
echo ""
echo "  Installed fonts:"
for font in "${NERD_FONTS[@]}"; do
  echo "    - $font Nerd Font"
done
echo ""
echo "  Set one of the above in your terminal:"
echo ""
echo "  GNOME Terminal / iTerm2 / Warp:"
echo "    Preferences > Profiles > Text > Custom font"
echo ""
echo "  VSCode:"
echo "    Settings > Terminal > Font Family"
echo ""
echo "=============================================="
echo ""
