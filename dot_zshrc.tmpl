export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""

plugins=(
  git
  zsh-completions
  zsh-autosuggestions
  zsh-syntax-highlighting
  uv
  chezmoi
)

# ===== 補完設定 =====
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
setopt list_packed
autoload colors
zstyle ':completion:*' list-colors ''

# コマンドのスペルを訂正
setopt correct

# ===== oh-my-zsh 初期化 =====
# NOTE: oh-my-zsh は内部で compinit を実行するため、明示的な compinit は不要
if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
else
  echo "oh-my-zsh not found at $ZSH; continuing without it." >&2
  # oh-my-zsh がない場合のみ手動で compinit を実行。キャッシュに保存し24時間だけ有効。
  autoload -Uz compinit
  if [[ -n ${ZDOTDIR}/.zcompdump(#qNmh+24) ]]; then
    compinit
  else
    compinit -C
  fi
fi

# ===== 標準設定 =====
HISTSIZE=10000
SAVEHIST=10000

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# Starship prompt
if type starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# ===== ROS2 設定（chezmoi feature flag管理） =====
{{- $features := get . "features" | default dict }}
{{- $ros2Enabled := get $features "ros2" | default false }}
{{- if and $ros2Enabled (eq .chezmoi.os "linux") }}
# ROS2 (Linux only)
autoload -Uz bashcompinit
bashcompinit

ros_setup_found=false
for setup in /opt/ros/*/setup.zsh(N); do
  source "$setup"
  export ROS_DOMAIN_ID=7
  ros_setup_found=true

  # Enable ROS2 shell completion if available.
  if [[ -n "$ROS_DISTRO" ]] && [[ -r /opt/ros/$ROS_DISTRO/share/ros2cli/environment/ros2-argcomplete.zsh ]]; then
    source /opt/ros/$ROS_DISTRO/share/ros2cli/environment/ros2-argcomplete.zsh
  fi
  break
done

if [[ "$ros_setup_found" != true ]]; then
  echo "ROS2 feature is enabled, but no /opt/ros/*/setup.zsh was found." >&2
fi

{{- else if and $ros2Enabled (eq .chezmoi.os "darwin") }}
# ROS2 (MacOS only)
if type pixi >/dev/null 2>&1; then
  eval "$(pixi completion --shell zsh)"

  # pixi環境に入ったら1回だけ補完を仕込む
  autoload -Uz add-zsh-hook
  _ros2_argcomplete_precmd() {
    [[ -n "${PIXI_ENVIRONMENT_NAME:-}" ]] || return
    command -v register-python-argcomplete >/dev/null 2>&1 || return

    autoload -Uz bashcompinit && bashcompinit
    eval "$(register-python-argcomplete ros2)"
    eval "$(register-python-argcomplete colcon)"

    # 一度設定できたら不要なので消す
    add-zsh-hook -d precmd _ros2_argcomplete_precmd
    unfunction _ros2_argcomplete_precmd 2>/dev/null
  }

  add-zsh-hook precmd _ros2_argcomplete_precmd
fi
{{- end }}
