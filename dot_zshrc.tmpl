export ZSH="$HOME/.oh-my-zsh"

# No theme - using Starship
ZSH_THEME=""

plugins=(
  git
  zsh-completions
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# 補完で小文字でも大文字にマッチさせる
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# 補完候補を詰めて表示
setopt list_packed

# 補完候補一覧をカラー表示
autoload colors
zstyle ':completion:*' list-colors ''

# コマンドのスペルを訂正
setopt correct

autoload -U compinit; compinit # zshの新しい補完システムを有効にする
autoload -U colors; colors # 色指定できるようにする

HISTSIZE=10000
SAVEHIST=10000

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
else
  echo "oh-my-zsh not found at $ZSH; continuing without it." >&2
fi

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# Starship prompt
if type starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

{{- $ros2Enabled := get (get . "features" | default dict) "ros2" | default false }}
{{- if $ros2Enabled }}
# ROS2 (Linux only; enabled through chezmoi feature flag)
if [[ "$OSTYPE" == linux* ]]; then
  autoload -Uz bashcompinit
  bashcompinit

  ros_setup_found=false
  for setup in /opt/ros/*/setup.zsh(N); do
    source "$setup"
    export ROS_DOMAIN_ID=7
    ros_setup_found=true

    # Enable ROS2 shell completion if available.
    if [[ -n "$ROS_DISTRO" ]] && [[ -r /opt/ros/$ROS_DISTRO/share/ros2cli/environment/ros2-argcomplete.zsh ]]; then
      source /opt/ros/$ROS_DISTRO/share/ros2cli/environment/ros2-argcomplete.zsh
    fi
    break
  done

  if [[ "$ros_setup_found" != true ]]; then
    echo "ROS2 feature is enabled, but no /opt/ros/*/setup.zsh was found." >&2
  fi
fi
{{- end }}
