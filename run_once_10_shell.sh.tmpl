{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
#!/usr/bin/env bash
set -euo pipefail

echo "=== [run_once_10_shell] Started at $(date) ==="

if ! command -v zsh >/dev/null 2>&1; then
  echo "zsh not found; skipping shell setup."
  exit 0
fi

ZSH_PATH="$(command -v zsh)"
CURRENT_SHELL="${SHELL:-}"

if [ "$CURRENT_SHELL" = "$ZSH_PATH" ]; then
  echo "zsh already set as default shell."
  exit 0
fi

echo "Setting default shell to: $ZSH_PATH"
if chsh -s "$ZSH_PATH" "$USER"; then
  echo "Default shell updated. Log out and back in to apply."
else
  echo "chsh failed. You may need to run: chsh -s $ZSH_PATH"
fi
{{- end -}}
