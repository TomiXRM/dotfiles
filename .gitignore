# Database / cache files
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
.vscode/*.db
.vscode/*.db-shm
.vscode/*.db-wal

# OS generated
.DS_Store
Thumbs.db

# Editor / IDE cache
*.swp
*.swo
*~
.*.un~

# Python cache
__pycache__/
*.pyc
*.pyo

# Compiled objects
*.o
*.so
*.dylib

# Logs
*.log

# Local tooling state
.serena/

# Editor settings
.vscode/

# Claude Code project-level state (not part of the dotfiles; ~/.claude is
# tracked via private_dot_claude/). Includes runtime lock files.
.claude/

# Scratch / working files (PDF sources, extraction, eval artifacts)
tmp/
